{
  "name": "hello-world",
  "version": "1.0.0",
  "description": "Comprehensive sample plugin demonstrating all Claude Code, Cursor, and Codex extension points.",
  "author": {
    "name": "yu-iskw"
  },
  "license": "Apache-2.0",
  "repository": "https://github.com/yu-iskw/claude-code-plugin-template",
  "homepage": "https://github.com/yu-iskw/claude-code-plugin-template",

  "platforms": {
    "claude": {
      "enabled": true,
      "mcpServers": "./.mcp.json",
      "lspServers": "./.lsp.json"
    },
    "cursor": {
      "enabled": true
    },
    "codex": {
      "enabled": true,
      "skills": "./skills/"
    }
  },

  "components": {
    "skills": {
      "enabled": true,
      "path": "./skills"
    },
    "agents": {
      "enabled": true,
      "path": "./agents"
    },
    "hooks": {
      "enabled": true,
      "path": "./hooks/hooks.json"
    },
    "mcp": {
      "enabled": true,
      "path": "./.mcp.json"
    },
    "lsp": {
      "enabled": true,
      "path": "./.lsp.json"
    }
  },

  "marketplace": {
    "claude": {
      "enabled": true,
      "tags": ["development", "examples", "tutorial"],
      "categories": ["development", "learning"],
      "author": {
        "name": "yu-iskw",
        "url": "https://github.com/yu-iskw"
      }
    },
    "cursor": {
      "enabled": true,
      "tags": ["development", "examples", "tutorial"],
      "categories": ["development"]
    },
    "codex": {
      "enabled": true,
      "tags": ["development", "examples"],
      "keywords": ["tutorial", "learning", "example"],
      "pricing": "free"
    }
  }
}
